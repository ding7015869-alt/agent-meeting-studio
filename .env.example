# Agent Meeting Studio — 环境变量（复制为 .env 并填入真实值）
# 服务端启动时自动加载 .env，无需 dotenv 依赖。
#
# 用法：把 agents.config.json 里 apiKeyEnv 设为左边的变量名，
# 然后在这里填对应的值。例如：
#   apiKeyEnv: "DEEPSEEK_API_KEY"  →  下面 DEEPSEEK_API_KEY=sk-xxx

# DeepSeek
DEEPSEEK_API_KEY=

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=

# 通用本地模型（Ollama / LM Studio 通常不需要）
LOCAL_MODEL_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# 自定义（随意扩展）
# CUSTOM_API_KEY=
